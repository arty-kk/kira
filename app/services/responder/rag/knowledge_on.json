    "tags": ["autoclicker", "battle", "automining", "active"]
  },
  {
    "id": "39",
    "text": "Defeating each creature makes the next stage of that creature stronger.",
    "category": "galaxytap",
    "tags": ["creature", "battle", "creature", "creatures", "monsters"]
  },
  {
    "id": "40",
    "text": "Each damage dealt in Battle mode per click consumes 1 battleship energy.",
