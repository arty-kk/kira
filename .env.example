#.env
DEFAULT_TZ=Europe/Moscow
LOG_LEVEL=INFO
# Optional per-process override: PROCESS_SPECIFIC_LOG_LEVEL has priority over LOG_LEVEL
# PROCESS_SPECIFIC_LOG_LEVEL=DEBUG
SQLALCHEMY_LOG_LEVEL=CRITICAL
# SQLAlchemy logs are suppressed by default; set ERROR/WARNING to debug DB issues

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_ID=
TG_PERSONA_CHAT_ID=11
TG_CHANNEL_ID=
PAYMENT_PROVIDER_TOKEN=
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_REGISTRATION_MAX_ATTEMPTS=5
WEBHOOK_REGISTRATION_RETRY_DELAY_SEC=2
QUEUE_KEY=queue:chat
USE_SELF_SIGNED_CERT=true
DP_USE_REDIS_STORAGE=true

#API
PUBLIC_API_BASE_URL=
API_KEY_HASH_SECRET="e++rNHRfP227WJC5clTAJgiQysoH4cpvhNbuYm00I60="

#Private UI / Buttons
ENABLE_PRIVATE_STATIC_WELCOME=false
ENABLE_PRIVATE_AI_WELCOME=true
CLEAR_SETUP_MESSAGES=true
SHOW_REQUESTS_BUTTON=true
SHOW_CHANNEL_BUTTON=false
SHOW_PERSONA_BUTTON=true
SHOW_API_BUTTON=true

#Addons
ENABLE_SCHEDULER=true
SCHED_ENABLE_KB_GC=true
ENABLE_GROUP_AI_WELCOME=false
SCHED_ENABLE_TWEETS=false
SCHED_ENABLE_PRICES=false
SCHED_ENABLE_GROUP_PING=false
SCHED_ENABLE_PERSONAL_PING=true
SCHED_ENABLE_BATTLE=false
SCHED_ENABLE_ANALYTICS=false
SCHED_ENABLE_TG_POSTS=false

#Moderation & Limits
ENABLE_MODERATION=false
MODERATOR_IDS=
ALLOWED_GROUP_IDS=
# Separate moderation scope for comment/discussion chats; independent from ALLOWED_GROUP_IDS.
COMMENT_MODERATION_ENABLED=false
# Target discussion/group chat IDs for comment moderation path (CSV integers).
COMMENT_TARGET_CHAT_IDS=
# Source channel IDs for linked discussion comments (CSV integers).
COMMENT_SOURCE_CHANNEL_IDS=
# Comment/discussion policy only (does not change default group moderation rules).
COMMENT_MODERATION_DELETE_EXTERNAL_REPLIES=false
# Comment/discussion link policy: group_default|relaxed.
COMMENT_MODERATION_LINK_POLICY=group_default
GROUP_DAILY_LIMIT=300
GROUP_AUTOREPLY_ON_TOPIC=true
MODERATION_TOXICITY_THRESHOLD=0.9

